{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "midi2otomad",
  "version": "0.3.5",
  "identifier": "com.kongyo2.midi2otomad",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ui && trunk serve",
    "beforeBuildCommand": "cd ui && trunk build --release"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "midi2otomad",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "backgroundColor": "#16161c",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "icon": ["../build/icon.png", "../build/icon.ico", "../build/icon.icns"]
  }
}
