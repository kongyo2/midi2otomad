{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsc/web.tsbuildinfo",
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": ["src/renderer/src/**/*", "src/shared/**/*"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
